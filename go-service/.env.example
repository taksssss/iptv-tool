# ---- Server ----------------------------------------------------------------
LISTEN_ADDR=:8080

# ---- Database --------------------------------------------------------------
# sqlite (default) or mysql
DB_TYPE=sqlite
DB_DSN=./data/data.db

# MySQL DSN (used when DB_TYPE=mysql)
# DB_DSN=user:password@tcp(127.0.0.1:3306)/phpepg?charset=utf8mb4&parseTime=true

# ---- Redis -----------------------------------------------------------------
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- Cache -----------------------------------------------------------------
# redis | memory | none
CACHE_TYPE=redis
# Cache TTL in seconds (default: 86400 = 24h)
CACHE_TTL=86400

# ---- Auth ------------------------------------------------------------------
# Newline-separated list of valid tokens (comma also works)
TOKENS=

# Token enforcement range:
#   0 = disabled (no token required)
#   1 = EPG endpoints only require token; live/proxy are free
#   2 = live/proxy endpoints only require token; EPG is free
#   3 = all endpoints require token
TOKEN_RANGE=1

# Allowed User-Agents (newline/comma separated)
USER_AGENTS=

# User-Agent enforcement range (same semantics as TOKEN_RANGE)
USER_AGENT_RANGE=0

# IP list mode:  0 = off,  1 = whitelist,  2 = blacklist
IP_LIST_MODE=0
# Path to the IP list file (one rule per line; supports CIDR and * wildcards)
IP_LIST_FILE=./data/ipList.txt

# ---- Proxy -----------------------------------------------------------------
# AES-256-CBC key token for stream URL encryption.
# Must match the "token" field in the PHP config.json for cross-compat.
PROXY_TOKEN=

# Upstream connect timeout in seconds
PROXY_TIMEOUT=10

# ---- Playlist / EPG --------------------------------------------------------
# Public base URL used in tvg-url and proxy rewrites (auto-detected if empty)
SERVER_URL=http://your-server-ip:8080

# ---- Logging ---------------------------------------------------------------
# debug | info | warn | error
LOG_LEVEL=info
ACCESS_LOG_ENABLE=true

# ---- Misc ------------------------------------------------------------------
# Data directory (shared with PHP service)
DATA_DIR=./data

# Default icon URL returned when no match is found
DEFAULT_ICON=

# Return 24-hour placeholder schedule when EPG data is unavailable
RET_DEFAULT=true
